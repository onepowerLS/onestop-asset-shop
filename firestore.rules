rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────
    // permissionLevel in users collection:
    //   6 = SuperAdmin, 5 = Admin → AM Admin
    //   3-4 = Approver/Manager   → AM Manager
    //   1-2 = Requester/Viewer   → AM Viewer

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function permLevel() {
      return userDoc().permissionLevel;
    }

    function isAdmin() {
      return isAuthenticated() && permLevel() >= 5;
    }

    function isManager() {
      return isAuthenticated() && permLevel() >= 3;
    }

    function isViewer() {
      return isAuthenticated();
    }

    function capDuplicateReview() {
      return isAuthenticated()
        && userDoc().keys().hasAll(['capabilities'])
        && userDoc().capabilities is map
        && userDoc().capabilities.duplicate_review == true;
    }

    function capAmOpsQueue() {
      return isAuthenticated()
        && userDoc().keys().hasAll(['capabilities'])
        && userDoc().capabilities is map
        && userDoc().capabilities.am_ops_queue_manage == true;
    }

    // Optional map on users/{uid}: capabilities.sim_team_assign, capabilities.sim_phone_link
    function capSimTeamAssign() {
      return userDoc().keys().hasAll(['capabilities'])
        && userDoc().capabilities is map
        && userDoc().capabilities.sim_team_assign == true;
    }

    function capSimPhoneLink() {
      return userDoc().keys().hasAll(['capabilities'])
        && userDoc().capabilities is map
        && userDoc().capabilities.sim_phone_link == true;
    }

    function canWriteSimCard() {
      return isAdmin() || capSimTeamAssign() || capSimPhoneLink();
    }

    function canWriteSimAssignment() {
      return isAdmin() ||
        (request.resource.data.assignment_type == 'team' && capSimTeamAssign()) ||
        (request.resource.data.assignment_type == 'phone_asset' && capSimPhoneLink()) ||
        ((request.resource.data.assignment_type == 'vehicle_tracker' ||
          request.resource.data.assignment_type == 'site_gateway' ||
          request.resource.data.assignment_type == 'other') &&
         (capSimTeamAssign() || capSimPhoneLink()));
    }

    function canUpdateSimAssignment() {
      return isAdmin() ||
        (request.resource.data.assignment_type == 'team' && capSimTeamAssign()) ||
        (request.resource.data.assignment_type == 'phone_asset' && capSimPhoneLink()) ||
        ((request.resource.data.assignment_type == 'vehicle_tracker' ||
          request.resource.data.assignment_type == 'site_gateway' ||
          request.resource.data.assignment_type == 'other') &&
         (capSimTeamAssign() || capSimPhoneLink()));
    }

    // ── AM core collections ─────────────────────────────────────

    match /am_core_assets/{docId} {
      allow read:   if isViewer();
      allow create: if isManager();
      allow update: if isManager();
      allow delete: if isAdmin();
    }

    match /am_core_allocations/{docId} {
      allow read:   if isViewer();
      allow create: if isManager();
      allow update: if isManager();
      allow delete: if isAdmin();
    }

    match /am_core_transactions/{docId} {
      allow read:   if isViewer();
      allow create: if isManager();
      allow update: if false;
      allow delete: if false;
    }

    match /am_core_inventory_levels/{docId} {
      allow read:   if isViewer();
      allow create: if isManager();
      allow update: if isManager();
      allow delete: if isAdmin();
    }

    // Duplicate merge snapshots; Managers create; Admin cron deletes expired.
    match /am_core_asset_purgatory/{docId} {
      allow read:   if isManager();
      allow create: if isManager();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // "Not duplicates" dismissals (review workspace)
    match /am_core_duplicate_dismissals/{docId} {
      allow read:   if isManager() || capDuplicateReview() || capAmOpsQueue();
      allow create: if isManager() || capDuplicateReview() || capAmOpsQueue();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Pending merge requests (reviewer → Manager executes)
    match /am_core_duplicate_merge_requests/{docId} {
      allow read:   if isManager() || capDuplicateReview() || capAmOpsQueue();
      allow create: if isManager() || capDuplicateReview() || capAmOpsQueue();
      allow update: if isManager();
      allow delete: if isManager() || isAdmin();
    }

    // Template-driven service requests (Ready boards, future types)
    match /am_core_requests/{docId} {
      allow read:   if isViewer();
      allow create: if isViewer();
      allow update: if isManager();
      allow delete: if isAdmin();
    }

    // HQ → site packing lists; trip_id links to Fleet Management trips (fm.1pwrafrica.com)
    match /am_core_loadout_manifests/{docId} {
      allow read:   if isViewer();
      allow create: if isManager();
      allow update: if isManager();
      allow delete: if isManager();
    }

    match /am_core_sim_cards/{docId} {
      allow read:   if isViewer();
      allow create, update: if canWriteSimCard();
      allow delete: if isAdmin();
    }

    match /am_core_sim_assignments/{docId} {
      allow read:   if isViewer();
      allow create: if canWriteSimAssignment();
      allow update: if canUpdateSimAssignment();
      allow delete: if isAdmin();
    }

    match /am_core_phone_requests/{docId} {
      allow read:   if isViewer();
      allow create: if isViewer();
      allow update: if isManager();
      allow delete: if isAdmin();
    }

    match /it_support_tickets/{docId} {
      allow read:   if isViewer();
      allow create: if isViewer();
      allow update: if isAdmin() || isManager() ||
        resource.data.requester_uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── AM PR master / shared collections ───────────────────────

    match /pr_master_categories/{docId} {
      allow read:   if isViewer();
      allow write:  if isAdmin();
    }

    match /pr_master_countries/{docId} {
      allow read:   if isViewer();
      allow write:  if isAdmin();
    }

    match /pr_master_locations/{docId} {
      allow read:   if isViewer();
      allow write:  if isAdmin();
    }

    match /pr_master_requests/{docId} {
      allow read:   if isViewer();
      allow create: if isViewer();
      allow update: if isManager();
      allow delete: if isAdmin();
    }

    match /pr_master_employees/{docId} {
      allow read:  if isViewer();
      allow write: if isAdmin();
    }

    // ── User profiles ───────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow update: if request.auth.uid == userId;
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── PR System reference data collections ────────────────────

    match /departments/{docId} {
      allow read, write: if true;
    }

    match /projectCategories/{docId} {
      allow read, write: if true;
    }

    match /sites/{docId} {
      allow read, write: if true;
    }

    match /expenseTypes/{docId} {
      allow read, write: if true;
    }

    match /vehicles/{docId} {
      allow read, write: if true;
    }

    match /vendors/{docId} {
      allow read, write: if true;
    }

    match /currencies/{docId} {
      allow read, write: if true;
    }

    // ── PR System purchase requests ─────────────────────────────

    match /purchaseRequests/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (resource.data.requestorId == request.auth.uid ||
         get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.permissionLevel <= 4);
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.permissionLevel <= 2;
    }

    // ── PR System archive ───────────────────────────────────────

    match /archivePRs/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Job Cards ───────────────────────────────────────────────

    match /jobCards/{jobCardId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ── Catch-all: allow authenticated access to any other
    //    collection (referenceData_*, etc.) ───────────────────────

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
